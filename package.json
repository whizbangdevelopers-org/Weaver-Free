{
  "name": "weaver",
  "version": "1.0.2",
  "description": "NixOS MicroVM Management Dashboard",
  "productName": "Weaver",
  "author": "whizBANG Developers LLC <dev@whizbangdevelopers.com>",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "private": true,
  "workspaces": [
    "backend",
    "tui"
  ],
  "scripts": {
    "generate:versions": "if [ -f ../scripts/delivery-projection.ts ]; then npx tsx ../scripts/delivery-projection.ts --codegen; fi",
    "predev": "npm run generate:versions",
    "prebuild": "npm run generate:versions && npm run audit:docs-links",
    "dev": "./scripts/check-ports.sh 9010 && quasar dev -m pwa",
    "dev:spa": "./scripts/check-ports.sh 9010 && quasar dev",
    "dev:backend": "./scripts/check-ports.sh 3110 && BRIDGE_GATEWAY=10.10.0.1 PREMIUM_ENABLED=true PROVISIONING_ENABLED=true MICROVMS_DIR=backend/data/microvms npm -w backend run dev -- --port 3110",
    "dev:provision": "./scripts/check-ports.sh 3110 && BRIDGE_GATEWAY=10.10.0.1 PREMIUM_ENABLED=true PROVISIONING_ENABLED=true MICROVMS_DIR=backend/data/microvms npm -w backend run dev -- --port 3110",
    "dev:demo-public": "./scripts/check-ports.sh 9030 && VITE_DEMO_MODE=true VITE_DEMO_PUBLIC=true quasar dev -p 9030",
    "dev:demo-private": "./scripts/check-ports.sh 9040 && VITE_DEMO_MODE=true quasar dev -p 9040",
    "dev:full": "./scripts/with-lock.sh dev bash -c './scripts/check-ports.sh 9010 3110 && npm run dev:backend & npm run dev'",
    "dev:full-provision": "./scripts/with-lock.sh dev bash -c './scripts/check-ports.sh 9010 3110 && npm run dev:provision & npm run dev'",
    "build": "quasar build -m pwa",
    "build:spa": "quasar build",
    "build:backend": "npm -w backend run build",
    "build:tui": "npm -w tui run build",
    "build:all": "npm run build && npm run build:backend && npm run build:tui",
    "build:release": "./scripts/build-release.sh",
    "deploy": "npm run build:all && cp -r dist/pwa/* /var/www/weaver/ && sudo systemctl restart weaver",
    "dev:tui": "./tui/node_modules/.bin/tsx watch tui/src/index.tsx",
    "start:tui": "node tui/dist/index.js",
    "lint": "eslint .",
    "lint:backend": "npm -w backend run lint",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:free": "vitest run --coverage --config vitest.free.config.ts",
    "test:backend": "npm -w backend test",
    "test:mutation": "npx stryker run",
    "test:mutation:quick": "npx stryker run --mutate 'src/utils/*.ts'",
    "test:security": "npx tsx scripts/audit-security.ts",
    "test:tui": "npm -w tui test",
    "test:precommit": "npm run lint && npm run typecheck && npm -w backend run lint && npm -w backend run typecheck && npm -w tui run typecheck && npm run test:unit:run && npm run test:backend && npm run test:tui",
    "test:prepush": "npm run test:precommit && npm run test:security && npm run test:compliance",
    "test:compliance": "npm run audit:vocabulary && npm run audit:forms && npm run audit:routes && npm run audit:e2e-coverage && npm run audit:e2e-selectors && npm run audit:legal && npm run audit:doc-freshness && npm run audit:tier-parity && npm run audit:tui-parity && npm run build:tui && npm run audit:cli-args && npm run audit:contrast && npm run audit:ws-codes && npm run audit:bundle && npm run audit:license && npm run audit:lockfile && npm run audit:sast && npm run audit:doc-parity && npm run audit:demo-parity && npm run audit:demo-guards && npm run audit:decision-parity && npm run audit:compliance-parity && npm run audit:compliance-matrix-parity && npm run audit:attribution && npm run audit:compatibility && npm run audit:license-parity && npm run audit:test-coverage && npm run audit:docs-links && npm run audit:nixos-version && npm run audit:project-parity && npm run audit:runbooks && npm run audit:eager-eval-tdz && npm run audit:excluded-imports && npm run audit:openssf-baseline && npm run audit:mcp-coverage && npm run audit:nix-deps-hash && npm run audit:sync-exclude-cruft && npm run audit:release-rsync-paths && npm run audit:nur-dispatch-completeness",
    "audit:excluded-imports": "npx tsx scripts/verify-excluded-imports.ts",
    "audit:openssf-baseline": "npx tsx scripts/verify-openssf-baseline.ts",
    "audit:mcp-coverage": "npx tsx scripts/verify-mcp-coverage.ts",
    "audit:nix-deps-hash": "npx tsx scripts/verify-nix-deps-hash.ts",
    "audit:sync-exclude-cruft": "npx tsx scripts/verify-sync-exclude-cruft.ts",
    "audit:release-rsync-paths": "npx tsx scripts/verify-release-rsync-paths.ts",
    "audit:nur-dispatch-completeness": "npx tsx scripts/verify-nur-dispatch-completeness.ts",
    "audit:release-builds": "npx tsx scripts/verify-release-builds.ts",
    "audit:release-builds:free": "npx tsx scripts/verify-release-builds.ts --context=free-tarball",
    "test:prerelease": "npm run test:prepush && npm run audit:release-builds && npm run e2e && npm run e2e:free",
    "dev:preview": "./scripts/dev-preview.sh",
    "clean": "rm -rf node_modules/.vite .quasar .q-cache 2>/dev/null; echo 'Cleared caches'",
    "fresh-install": "./scripts/fresh-install.sh",
    "audit:forms": "npx tsx scripts/verify-form-rules.ts",
    "audit:doc-freshness": "npx tsx scripts/verify-doc-freshness.ts",
    "generate:cashflow": "npx tsx scripts/generate-cashflow.ts",
    "audit:e2e-coverage": "npx tsx scripts/verify-form-e2e-coverage.ts",
    "audit:legal": "npx tsx scripts/verify-legal-ip.ts",
    "audit:routes": "npx tsx scripts/verify-route-auth.ts",
    "audit:tier-parity": "npx tsx scripts/verify-tier-parity.ts",
    "audit:tui-parity": "npx tsx scripts/verify-tui-parity.ts",
    "audit:cli-args": "npx tsx scripts/verify-cli-args.ts",
    "audit:contrast": "npx tsx scripts/verify-contrast.ts",
    "audit:bundle": "npx tsx scripts/check-bundle-size.ts",
    "audit:ws-codes": "npx tsx scripts/verify-ws-codes.ts",
    "audit:license": "npx tsx scripts/audit-licenses.ts",
    "audit:lockfile": "npx tsx scripts/verify-lockfile.ts",
    "audit:sast": "npx tsx scripts/audit-sast.ts",
    "audit:demo-parity": "npx tsx scripts/verify-demo-parity.ts",
    "audit:demo-guards": "npx tsx scripts/verify-demo-guards.ts",
    "audit:decision-parity": "npx tsx scripts/verify-decision-parity.ts",
    "audit:doc-parity": "npx tsx scripts/verify-doc-parity.ts",
    "audit:e2e-selectors": "npx tsx scripts/verify-e2e-selectors.ts",
    "audit:compliance-parity": "npx tsx scripts/verify-compliance-parity.ts",
    "audit:compliance-matrix-parity": "npx tsx scripts/verify-compliance-matrix-parity.ts",
    "gen:compliance-matrix": "npx tsx scripts/gen-compliance-matrix.ts",
    "audit:attribution": "npx tsx scripts/verify-attribution-parity.ts",
    "audit:vocabulary": "npx tsx scripts/verify-vocabulary-sync.ts",
    "audit:compatibility": "npx tsx scripts/verify-compatibility-sync.ts",
    "audit:license-parity": "npx tsx scripts/verify-license-parity.ts",
    "audit:test-coverage": "npx tsx scripts/verify-test-coverage.ts",
    "audit:nixos-version": "npx tsx scripts/verify-nixos-version.ts",
    "audit:project-parity": "npx tsx scripts/verify-project-parity.ts",
    "audit:docs-links": "if [ -f scripts/verify-docs-links.ts ]; then npx tsx scripts/verify-docs-links.ts; fi",
    "audit:runbooks": "npx tsx scripts/verify-runbooks.ts",
    "audit:eager-eval-tdz": "npx tsx scripts/verify-eager-eval-tdz.ts",
    "docs:snapshot": "bash scripts/snapshot-docs.sh",
    "verify:release": "npx tsx scripts/verify-post-release.ts",
    "test:manual": "npx tsx scripts/manual-test-checklist.ts",
    "test:manual:verify": "npx tsx scripts/manual-test-checklist.ts --verify",
    "test:load": "k6 run testing/load/k6/api-scale.js",
    "test:load:ws": "k6 run testing/load/ws/ws-scale.js",
    "test:load:frontend": "npx playwright test testing/load/frontend/topology-perf.spec.ts",
    "test:distros": "npx tsx scripts/test-distro-catalog.ts",
    "test:distros:all": "npx tsx scripts/test-distro-catalog.ts --all",
    "test:distros:dry": "npx tsx scripts/test-distro-catalog.ts --dry-run",
    "test:distros:preload": "npx tsx scripts/test-distro-catalog.ts --preload",
    "test:distros:cleanup": "npx tsx scripts/test-distro-catalog.ts --cleanup",
    "e2e": "testing/e2e-docker/scripts/run-tests.sh; testing/e2e-docker/scripts/analyze-results.sh",
    "e2e:browsers": "testing/e2e-docker/scripts/run-tests-browsers.sh; testing/e2e-docker/scripts/analyze-results.sh",
    "e2e:free": "testing/e2e-docker/scripts/run-tests-free.sh",
    "e2e:demo-public": "testing/e2e-docker/scripts/run-tests-demo-public.sh",
    "e2e:demo-private": "testing/e2e-docker/scripts/run-tests-demo-private.sh",
    "badge:e2e": "node -e 'const [p,f]=process.argv.slice(2);if(!p){console.error(\"usage: npm run badge:e2e -- <passed> [failed]\");process.exit(1)}console.log(`gh workflow run update-e2e-badge.yml -f passed=${p} -f failed=${f||0}`)'",
    "e2e:demo-screenshots": "testing/e2e-docker/scripts/run-tests-demo-screenshots.sh",
    "e2e:single": "testing/e2e-docker/scripts/run-single.sh",
    "e2e:analyze": "testing/e2e-docker/scripts/analyze-results.sh",
    "e2e:live": "./scripts/with-lock.sh e2e ./scripts/nix-fresh-test.sh",
    "e2e:live:free": "./scripts/with-lock.sh e2e ./scripts/nix-fresh-test.sh --tier free",
    "e2e:live:skip-build": "./scripts/with-lock.sh e2e ./scripts/nix-fresh-test.sh --skip-build",
    "browser:up": "docker compose -f testing/e2e-docker/docker-compose.yml --profile browser up -d",
    "browser:down": "docker compose -f testing/e2e-docker/docker-compose.yml --profile browser down"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.15.0",
    "idb": "^8.0.0",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "quasar": "^2.14.0",
    "sortablejs": "^1.15.7",
    "v-network-graph": "^0.9.22",
    "vue": "^3.5.27",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@quasar/app-vite": "^2.4.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.30",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.16",
    "@vue/test-utils": "^2.4.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.0",
    "register-service-worker": "^1.7.2",
    "sass": "^1.97.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.11",
    "vitest": "^4.0.16",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.2",
    "workbox-build": "^7.4.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
