# Server
PORT=3110
NODE_ENV=development

# Port assignments (do not overlap):
#   3100 = NixOS systemd service (production)
#   3110 = dev backend (npm run dev:backend)
#   3120 = e2e tests / provisioning dev
#   3130 = e2e:live backend
#   9010 = dev frontend
#   9020 = e2e frontend
#   9030 = public demo (local testing, SPA-only)
#   9040 = private demo (local testing, SPA-only)
#   9120 = provisioning dev frontend

# CORS
CORS_ORIGIN=http://localhost:9010

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=app_db

# Premium Features
PREMIUM_ENABLED=false

# VM Storage (json or sqlite)
VM_STORAGE_BACKEND=json
VM_DATA_DIR=./data

# Distro Catalog (optional remote URL to refresh curated catalog)
# DISTRO_CATALOG_URL=https://example.com/distro-catalog.json

# VM Provisioning (enabled by default on NixOS, sets up bridge/NAT automatically)
PROVISIONING_ENABLED=true
MICROVMS_DIR=/var/lib/microvms
BRIDGE_GATEWAY=10.10.0.1
BRIDGE_INTERFACE=br-microvm
MICROVM_BIN=/run/current-system/sw/bin/microvm
QEMU_BIN=/run/current-system/sw/bin/qemu-system-x86_64
QEMU_IMG_BIN=/run/current-system/sw/bin/qemu-img
IP_BIN=/run/current-system/sw/bin/ip

# SMTP (transactional emails — license key delivery, etc.)
# Leave SMTP_HOST unset to disable email sending.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Weaver <licenses@whizbangdevelopers.com>
# EMAIL_REPLY_TO=Weaver Support <support@whizbangdevelopers.com>
