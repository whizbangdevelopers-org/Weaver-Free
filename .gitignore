# Testing
playwright-report/
test-results/
coverage/
coverage-free/
testing/e2e-docker/output/

# Audit & test reports (auto-generated by scripts/)
reports/
# Exception: LLGD coverage baseline is a point-in-time archival artifact
# (v1.0.2 → v1.0.4 before/after comparison — spec: plans/v1.0.2/LLGD-BACKFILL-SPEC.md).
# Re-runs of the script overwrite the tracked file; commits capture each
# snapshot across release cycles. Directory itself must be un-ignored so
# gitignore considers files inside it.
!reports/
reports/*
!reports/llgd-coverage-baseline.json
!reports/llgd-coverage-baseline.md

# Manual test baseline (user-local state)
testing/.last-verified-sha
scripts/.fresh-install-count

# Playwright auth state (generated by E2E global-setup)
.auth/

# Stryker mutation testing
.stryker-tmp/

# Temporary files
tmp/

# Quasar SCSS compiled output (build artifacts — source is *.scss)
src/css/*.css
src/css/*.css.map

# Live E2E (nix-fresh-test.sh runtime state)
backend/data-live-e2e/
testing/live-e2e-output/
.live-e2e-backend.pid
.live-e2e-backend.log

# Data (user-generated)
data/
!backend/data/
backend/data/*
!backend/data/distro-catalog.json
!scripts/data/

# SBOM (build artifacts from CycloneDX)
sbom*.json

# Environment
.env
.env.local
.env.*.local

# Personal working notes (not product-bundled)
docs/security/CII-BEST-PRACTICES-ANSWERS.md
